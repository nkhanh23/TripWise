    "styleDefinitionBrief": "Premium travel-tech cockpit UI with a warm outer frame, cool clean core, HUD map overlays, and a calm itinerary-to-map focus loop.",
    "designRead": "Trip planner detail screen / self-serve travelers / warm cockpit precision / high density / avoid generic flat admin UI",
    "designDials": {
      "layoutVariance": 2,
      "motionIntensity": 2,
      "visualDensity": 4
    },
    "styleContinuityAnchors": {
      "colorSystem": {
        "primaryColorRole": "Bright blue is reserved for route focus, selected timeline rows, active navigation, and primary CTA moments.",
        "brandHuePolicy": "Warm beige outer canvas frames a cool neutral shell; no extra brand accent hue beyond semantic warning and error tags.",
        "stateColors": "Lime for optimized, amber for rain risk, red for over budget or route failure."
      },
      "shapeSystem": "Large shell radius around 30px, cards at 16px, controls at 12px, and pill tags for compact cockpit readability.",
      "typographySystem": "Inter-led dashboard typography with bold 22-24px titles, 14px body copy, and 11-12px micro labels using tabular numerals.",
      "spacingSystem": "Tight premium density with 8-12px internal rhythm inside cards and 16-24px shell padding so the left panel feels like an instrument cluster.",
      "componentLanguage": "Crisp stats blocks, segmented day tabs, list-forward timeline rows, semi-opaque map HUD cards, and minimal icon chrome.",
      "surfaceAndDepth": "Soft premium shadows, subtle borders, and layered white-on-cool panels inside a warm outer frame.",
      "imageryAndIconography": "Map-first vector treatment with OSM-like roads, numbered blue markers, and compact transport/weather glyphs rather than decorative photos.",
      "interactionTone": "Fast calm transitions, obvious selection states, smooth focus movement, and no flashy motion."
    },
    "specsConstraints": null,
    "sharedProjectShellContract": {
      "navigationShell": "Icon-only sidebar on desktop state pages, no heavyweight top app bar, and map-first mobile chrome with floating HUD surfaces.",
      "primaryColorSystem": "Use #2F7BFF for selected states, route geometry, marker emphasis, and the primary action only.",
      "typographySystem": "Inter with tabular numerals, bold condensed hierarchy, and slate-toned supporting text.",
      "radiusScale": "30px shell, 16px cards, 12px controls, pill tags.",
      "surfaceDepthModel": "Warm page background outside, cool neutral shell inside, white cards, subtle bezel border, and stronger map-overlay depth.",
      "ctaStyle": "Compact rounded blue buttons with minimal icon pairing and muted secondary controls.",
      "alignmentRules": "Three-zone desktop split with sidebar + left trip panel + right map panel; map overlays keep safe areas clear."
    },
