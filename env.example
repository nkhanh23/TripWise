APP_ENV=local
SERVER_PORT=8080

DATABASE_URL=jdbc:postgresql://localhost:5432/ai_smart_travel_planner
DATABASE_USERNAME=ai_travel_app
DATABASE_PASSWORD=change_me_local_postgres_password

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change_me_32_bytes_minimum_access_secret_for_local_only
JWT_REFRESH_SECRET=change_me_32_bytes_minimum_refresh_secret_for_local_only
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30

GEMINI_API_KEY=change_me_gemini_api_key

OSRM_BASE_URL=https://router.project-osrm.org

WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com

GOOGLE_PLACES_API_KEY=change_me_google_places_api_key_optional_for_local

OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=ai-smart-travel-planner-local
OBJECT_STORAGE_ACCESS_KEY=change_me_object_storage_access_key
OBJECT_STORAGE_SECRET_KEY=change_me_object_storage_secret_key

CDN_BASE_URL=http://localhost:9000/ai-smart-travel-planner-local

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

RATE_LIMIT_REDIS_PREFIX=ai-travel:rate-limit:

LOG_LEVEL=INFO
